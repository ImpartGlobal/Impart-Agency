# ─────────────────────────────────────────────
#  Impart Agency — Environment Variables
#  Copy this file to .env.local and fill in values.
#  NEVER commit .env.local to source control.
# ─────────────────────────────────────────────

# Contact form endpoint (e.g. Formspree, Netlify Forms, custom API route)
NEXT_PUBLIC_FORM_ENDPOINT=

# WhatsApp business number (international format, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=27xxxxxxxxx

# Google Analytics / GTM
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps embed key (for contact page map)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Social media profile URLs
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_TWITTER_URL=
